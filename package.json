{
  "name": "homebridge-openclaw-gateway",
  "displayName": "OpenClaw Gateway",
  "version": "3.1.0",
  "description": "Expose a REST API and built-in event engine so OpenClaw agents can control HomeKit devices and react to state changes via Homebridge.",
  "main": "index.js",
  "scripts": {
    "test": "node --test",
    "publish:npm": "npm publish --cache /tmp/openclaw-npm-cache",
    "publish:npm:dry-run": "npm pack --dry-run --cache /tmp/openclaw-npm-cache"
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "homekit",
    "openclaw",
    "smart-home",
    "rest-api"
  ],
  "engines": {
    "node": ">=18.0.0",
    "homebridge": ">=1.6.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "jsonwebtoken": "^9.0.2"
  },
  "author": "Robert Day <day.c.robert@gmail.com>",
  "contributors": [
    "Davide Vargas P. <davidevp@hotmail.com> (https://github.com/davidevp)"
  ],
  "license": "MIT",
  "files": [
    "index.js",
    "lib/",
    "config.schema.json",
    "homebridge-ui-logo.png",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dayrobert/homebridge-openclaw-gateway.git"
  },
  "homepage": "https://github.com/dayrobert/homebridge-openclaw-gateway#readme",
  "bugs": {
    "url": "https://github.com/dayrobert/homebridge-openclaw-gateway/issues"
  }
}
